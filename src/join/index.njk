---
layout: base
title: Connect on ReferVo
description: Join ReferVo to connect with this business partner.
---

<style>
  .join-container {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  }
  
  .join-card {
    background: var(--white);
    border-radius: 24px;
    padding: 3rem 2rem;
    max-width: 400px;
    width: 100%;
    box-shadow: 0 4px 24px rgba(0,0,0,0.1);
  }
  
  .join-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }
  
  .join-icon svg {
    width: 40px;
    height: 40px;
    color: white;
  }
  
  .join-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--black);
    margin-bottom: 0.75rem;
  }
  
  .join-subtitle {
    color: var(--gray-text);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  
  .join-code {
    background: var(--gray-light);
    border-radius: 12px;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
  }
  
  .join-code-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--gray-text);
    margin-bottom: 0.5rem;
  }
  
  .join-code-value {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: 3px;
    color: var(--black);
  }
  
  .join-code-hint {
    font-size: 0.75rem;
    color: var(--gray-text);
    margin-top: 0.5rem;
  }
  
  .join-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 1rem 1.5rem;
    background: var(--primary);
    color: white;
    border-radius: 12px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  
  .join-btn:hover {
    background: var(--primary-dark);
  }
  
  .redirect-notice {
    margin-top: 1.5rem;
    font-size: 0.875rem;
    color: var(--gray-text);
  }
  
  .countdown {
    font-weight: 600;
    color: var(--primary);
  }
</style>

<section class="join-container">
  <div class="join-card">
    <div class="join-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
    </div>
    
    <h1 class="join-title">You've Been Invited!</h1>
    <p class="join-subtitle">Someone wants to connect with you on ReferVo.</p>
    
    <div class="join-code" id="codeDisplay" style="display: none;">
      <div class="join-code-label">Your Connect Code</div>
      <div class="join-code-value" id="connectCode"></div>
      <div class="join-code-hint">Enter this code in the app to connect</div>
    </div>
    
    <a href="{{ site.appStoreUrl }}" class="join-btn" id="downloadBtn">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
      </svg>
      Open ReferVo
    </a>
    
    <p class="redirect-notice" id="redirectNotice" style="display: none;">
      Opening App Store in <span class="countdown" id="countdown">3</span> seconds...
    </p>
  </div>
</section>

<script>
  (function() {
    var path = window.location.pathname;
    var match = path.match(/\/join\/([0-9]+)/i);
    
    if (match && match[1]) {
      var code = match[1];
      var codeDisplay = document.getElementById('codeDisplay');
      var connectCode = document.getElementById('connectCode');
      var redirectNotice = document.getElementById('redirectNotice');
      var countdownEl = document.getElementById('countdown');
      
      // Show the code
      connectCode.textContent = code;
      codeDisplay.style.display = 'block';
      redirectNotice.style.display = 'block';
      
      // Countdown and redirect
      var seconds = 3;
      var timer = setInterval(function() {
        seconds--;
        countdownEl.textContent = seconds;
        if (seconds <= 0) {
          clearInterval(timer);
          window.location.href = '{{ site.appStoreUrl }}';
        }
      }, 1000);
    }
  })();
</script>
