<article class="article-card">
  <a href="{{ article.url }}" class="article-card-image">
    {% if article.data.featured_image %}
      <img src="{{ article.data.featured_image }}" alt="{{ article.data.title }}" loading="lazy">
    {% else %}
      <div class="article-card-placeholder">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
      </div>
    {% endif %}
    <span class="article-card-category">{{ article.data.category | capitalize }}</span>
  </a>
  <div class="article-card-content">
    <h3><a href="{{ article.url }}">{{ article.data.title }}</a></h3>
    <p>{{ article.data.excerpt | default(article.templateContent | striptags | truncate(150)) }}</p>
    <div class="article-card-meta">
      <time datetime="{{ article.data.date | isoDate }}">{{ article.data.date | dateFormat("MMMM D, YYYY") }}</time>
      <a href="{{ article.url }}" class="read-more">Read more →</a>
    </div>
  </div>
</article>