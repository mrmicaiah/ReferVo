<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default(site.name + " - " + site.tagline) }}</title>
  <meta name="description" content="{{ meta_description | default(description) | default(site.description) }}">
  <meta name="keywords" content="{{ keywords | default('business referral app, referral fee, finder\'s fee, contractor referrals, referral marketing, word of mouth marketing, get paid for referrals, referral payments') }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  
  {# Open Graph #}
  <meta property="og:title" content="{{ title | default(site.name) }}">
  <meta property="og:description" content="{{ meta_description | default(description) | default(site.description) }}">
  <meta property="og:type" content="{% if layout == 'article' %}article{% else %}website{% endif %}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ ogImage | default(featured_image) | default(site.cloudinary.base + '/' + site.cloudinary.iconMaster) }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:locale" content="en_US">
  {% if layout == 'article' %}
  <meta property="article:published_time" content="{{ date | isoDate }}">
  <meta property="article:author" content="{{ author | default('ReferVo Team') }}">
  <meta property="article:section" content="{{ category | capitalize }}">
  {% endif %}
  
  {# Twitter Card #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@refervo">
  <meta name="twitter:title" content="{{ title | default(site.name) }}">
  <meta name="twitter:description" content="{{ meta_description | default(description) | default(site.description) }}">
  <meta name="twitter:image" content="{{ ogImage | default(featured_image) | default(site.cloudinary.base + '/' + site.cloudinary.iconMaster) }}">
  
  {# Favicon #}
  <link rel="icon" type="image/png" href="{{ site.cloudinary.base }}/{{ site.cloudinary.icon512 }}">
  <link rel="apple-touch-icon" href="{{ site.cloudinary.base }}/{{ site.cloudinary.icon512 }}">
  
  {# RSS Feed #}
  <link rel="alternate" type="application/atom+xml" title="{{ site.name }} Blog" href="{{ site.url }}/feed.xml">
  
  {# Schema.org Markup #}
  {% if layout == 'article' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ title }}",
    "datePublished": "{{ date | isoDate }}",
    "dateModified": "{{ date | isoDate }}",
    "author": {
      "@type": "Organization",
      "name": "{{ author | default('ReferVo Team') }}",
      "url": "{{ site.url }}"
    },
    "publisher": {
      "@type": "Organization",
      "name": "ReferVo",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ site.cloudinary.base }}/{{ site.cloudinary.icon512 }}"
      }
    },
    "description": "{{ meta_description | default(excerpt) | default(description) }}",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ site.url }}{{ page.url }}"
    }
    {% if featured_image %},
    "image": "{{ featured_image }}"
    {% endif %}
  }
  </script>
  {% elif faq %}
  {# FAQPage Schema for landing pages with FAQ #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for item in faq %}{
        "@type": "Question",
        "name": "{{ item.q | escape }}",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "{{ item.a | escape }}"
        }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "{{ site.name }}",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "iOS",
    "description": "{{ site.description }}",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "ratingCount": "1"
    }
  }
  </script>
  {% else %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "{{ site.name }}",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "iOS",
    "description": "{{ site.description }}",
    "url": "{{ site.url }}",
    "downloadUrl": "{{ site.appStoreUrl }}",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "ratingCount": "1"
    }
  }
  </script>
  {% endif %}
  
  {# Organization Schema (all pages) #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "ReferVo",
    "url": "{{ site.url }}",
    "logo": "{{ site.cloudinary.base }}/{{ site.cloudinary.iconMaster }}",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "{{ site.email.support }}",
      "contactType": "customer support"
    }
  }
  </script>
  
  {# Preconnect - Performance #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://res.cloudinary.com">
  <link rel="dns-prefetch" href="https://res.cloudinary.com">
  
  {# Fonts #}
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
  
  {# Styles #}
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/utilities.css">
  <link rel="stylesheet" href="/css/blog.css">
  <link rel="stylesheet" href="/css/landing.css">
  <link rel="stylesheet" href="/css/email-capture.css">
  {% if extraCss %}
  <link rel="stylesheet" href="/css/{{ extraCss }}">
  {% endif %}
  
  {# Google Analytics 4 - Replace GA_MEASUREMENT_ID with actual ID #}
  {% if site.ga4Id %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.ga4Id }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.ga4Id }}');
  </script>
  {% endif %}
  
  {% block head %}{% endblock %}
</head>
<body>
  
  {% include "partials/header.njk" %}
  
  <main>
    {% block content %}
    {{ content | safe }}
    {% endblock %}
  </main>
  
  {% include "partials/footer.njk" %}
  
  <script src="/js/main.js"></script>
  {% block scripts %}{% endblock %}
  
</body>
</html>
